)
# 2-Factor Model (based on theory)
model_2f <- paste0(
"Factor_CM =~ ", paste(cm_vars, collapse = " + "), "\n",
"Factor_CB =~ ", paste(cb_vars, collapse = " + ")
)
# Fit both models
fit_1f <- cfa(model_1f, data = study2_data, std.lv = TRUE)
fit_2f <- cfa(model_2f, data = study2_data, std.lv = TRUE)
# ANOVA Chi-Square Difference Test
model_comp <- anova(fit_1f, fit_2f)
chi_diff <- round(model_comp$`Chisq diff`[2], 2)
df_diff <- model_comp$`Df diff`[2]
p_diff <- model_comp$`Pr(>Chisq)`[2]
# Formulate the significance string for the article
p_string <- ifelse(p_diff < 0.001, "p < .001", paste0("p = ", round(p_diff, 3)))
manuscript_text <- paste0("A chi-square difference test revealed that the theory-driven 2-factor model fit the data significantly better than the exploratory 1-factor model (Δχ²(", df_diff, ") = ", chi_diff, ", ", p_string, ").")
# Extract key fit stats
extract_fit <- function(fit, name) {
meas <- fitMeasures(fit, c("chisq", "df", "pvalue", "cfi", "tli", "rmsea", "srmr", "bic"))
data.frame(
Model = name,
Chi_Square = round(meas["chisq"], 2),
df = meas["df"],
CFI = round(meas["cfi"], 3),
TLI = round(meas["tli"], 3),
RMSEA = round(meas["rmsea"], 3),
SRMR = round(meas["srmr"], 3),
BIC = round(meas["bic"], 2),
stringsAsFactors = FALSE
)
}
comparison_df <- rbind(
extract_fit(fit_1f, "1-Factor (Exploratory)"),
extract_fit(fit_2f, "2-Factor (Theory-Driven)")
)
# save
output_path <- here("Output", "H0", "Robustness", "Study2_Dimensionality_Check.doc")
dir.create(dirname(output_path), recursive = TRUE, showWarnings = FALSE)
tab_df(
comparison_df,
title = "Study 2: Dimensionality Robustness Check (1-Factor vs 2-Factor)",
file = output_path
)
# Print
print(manuscript_text)
