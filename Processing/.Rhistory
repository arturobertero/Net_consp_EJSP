EGAnet, qgraph, semPlot, haven, janitor, readxl, labelled, countrycode,
openxlsx)
rm(list = ls())
# Import cleaned data
data = readRDS(here("Input", "Secondary", "data.rds"))
us = readRDS(here("Input", "Secondary", "USA_clean.rds"))
#Na.omit and common structure
data = data %>%
select(country, GCB, CB, gcb_1:cb_8) %>%
