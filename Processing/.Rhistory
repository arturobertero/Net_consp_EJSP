# Study 2 data
study2_name <- names(H0_matrices)[grepl("Study2", names(H0_matrices))]
study2_data <- as.data.frame(H0_matrices[[study2_name]])
var_names <- colnames(study2_data)
# take the items
cm_vars <- var_names[grepl("^cm_", var_names)]
cb_vars <- var_names[grepl("^cb_", var_names)]
# 1-Factor Model (EGA's suggestion)
model_1f <- paste0(
"General_Factor =~ ", paste(c(cm_vars, cb_vars), collapse = " + ")
)
# 2-Factor Model (based on theory)
model_2f <- paste0(
"Factor_CM =~ ", paste(cm_vars, collapse = " + "), "\n",
"Factor_CB =~ ", paste(cb_vars, collapse = " + ")
)
# Fit both models
fit_1f <- cfa(model_1f, data = study2_data, std.lv = TRUE)
fit_2f <- cfa(model_2f, data = study2_data, std.lv = TRUE)
# ANOVA Chi-Square Difference Test
model_comp <- anova(fit_1f, fit_2f)
chi_diff <- round(model_comp$`Chisq diff`[2], 2)
df_diff <- model_comp$`Df diff`[2]
p_diff <- model_comp$`Pr(>Chisq)`[2]
# Formulate the significance string for the article
p_string <- ifelse(p_diff < 0.001, "p < .001", paste0("p = ", round(p_diff, 3)))
manuscript_text <- paste0("A chi-square difference test revealed that the theory-driven 2-factor model fit the data significantly better than the exploratory 1-factor model (Δχ²(", df_diff, ") = ", chi_diff, ", ", p_string, ").")
# Extract key fit stats
extract_fit <- function(fit, name) {
meas <- fitMeasures(fit, c("chisq", "df", "pvalue", "cfi", "tli", "rmsea", "srmr", "bic"))
data.frame(
Model = name,
Chi_Square = round(meas["chisq"], 2),
df = meas["df"],
CFI = round(meas["cfi"], 3),
TLI = round(meas["tli"], 3),
RMSEA = round(meas["rmsea"], 3),
SRMR = round(meas["srmr"], 3),
BIC = round(meas["bic"], 2),
stringsAsFactors = FALSE
)
}
comparison_df <- rbind(
extract_fit(fit_1f, "1-Factor (Exploratory)"),
extract_fit(fit_2f, "2-Factor (Theory-Driven)")
)
# save
output_path <- here("Output", "H0", "Robustness", "Study2_Dimensionality_Check.doc")
dir.create(dirname(output_path), recursive = TRUE, showWarnings = FALSE)
tab_df(
comparison_df,
title = "Study 2: Dimensionality Robustness Check (1-Factor vs 2-Factor)",
file = output_path
)
# Print
print(manuscript_text)
# Target the problematic countries
target_countries <- c("Study3_CMQ_Canada", "Study3_CMQ_United States")
# Function to extract fit safely (the us model crashes)
extract_fit <- function(fit, name) {
if (is.null(fit)) {
return(data.frame(
Model = name, Chi_Square = NA, df = NA, CFI = NA, TLI = NA,
RMSEA = NA, SRMR = NA, BIC = NA, stringsAsFactors = FALSE
))
}
meas <- fitMeasures(fit, c("chisq", "df", "pvalue", "cfi", "tli", "rmsea", "srmr", "bic"))
data.frame(
Model = name,
Chi_Square = round(meas["chisq"], 2),
df = meas["df"],
CFI = round(meas["cfi"], 3),
TLI = round(meas["tli"], 3),
RMSEA = round(meas["rmsea"], 3),
SRMR = round(meas["srmr"], 3),
BIC = round(meas["bic"], 2),
stringsAsFactors = FALSE
)
}
for (country in target_countries) {
clean_name <- gsub("Study3_CMQ_", "", country)
# data matrix and variable names
data_matrix <- as.data.frame(H0_matrices[[country]])
var_names <- colnames(data_matrix)
# 2-Factor Model (theory based)
cm_vars <- var_names[grepl("^cm_", var_names)]
cb_vars <- var_names[grepl("^cb_", var_names)]
model_2f <- paste0(
"Factor_CM =~ ", paste(cm_vars, collapse = " + "), "\n",
"Factor_CB =~ ", paste(cb_vars, collapse = " + ")
)
# 3-Factor Model based on EGA's $wc output
wc_result <- EGA_results[[country]]$wc
model_3f <- ""
for (dim in unique(wc_result)) {
if (!is.null(names(wc_result))) {
dim_vars <- names(wc_result)[wc_result == dim]
} else {
dim_vars <- var_names[which(wc_result == dim)]
}
model_3f <- paste0(model_3f, "EGA_Dim_", dim, " =~ ", paste(dim_vars, collapse = " + "), "\n")
}
# Fit both
# If a model fails to converge, it returns NULL
fit_3f <- tryCatch(suppressWarnings(cfa(model_3f, data = data_matrix, std.lv = TRUE)), error = function(e) NULL)
fit_2f <- tryCatch(suppressWarnings(cfa(model_2f, data = data_matrix, std.lv = TRUE)), error = function(e) NULL)
# Check for non-convergence manually
if (!is.null(fit_3f) && !lavInspect(fit_3f, "converged")) fit_3f <- NULL
if (!is.null(fit_2f) && !lavInspect(fit_2f, "converged")) fit_2f <- NULL
# Extract fit stats
comp_df <- rbind(
extract_fit(fit_3f, "3-Factor (Exploratory)"),
extract_fit(fit_2f, "2-Factor (Theory-Driven)")
)
# Print
cat("\n======================================================\n")
cat("RESULTS FOR:", clean_name, "\n")
cat("======================================================\n")
print(comp_df)
cat("\n")
}
#Libraries
library(pacman)
p_load(lavaan, rio, tidyverse, psych, here, stargazer, summarytools, visdat,
EGAnet, qgraph, ggplot2, haven, janitor, readxl, labelled, reshape2,
openxlsx, mgm, bootnet, conflicted, magick, cocron, lme4, broom.mixed,
patchwork, knitr, kableExtra, sjPlot, lavaan)
#Options
rm(list = ls())
options(scipen = 999)
#conflicts
conflicts_prefer(dplyr::filter)
conflicts_prefer(dplyr::select)
# Data
master_datasets <- readRDS(here("Input", "Secondary", "master_datasets.rds"))
# Initialize objects for EGA
# an empty list to hold the matrices for every country across all studies
H0_matrices <- list()
# Loop through the master list to extract and split data
for (study_name in names(master_datasets)) {
# Extract the dataset
df <- master_datasets[[study_name]]
# Keep only country, cm_, and cb_ items, then drop NAs
df_clean <- df %>%
select(country, starts_with("cm_"), starts_with("cb_")) %>%
na.omit()
# Split by country
split_df <- split(df_clean[, setdiff(names(df_clean), "country")], df_clean$country)
# Convert to matrices and assign unique names
for (country_name in names(split_df)) {
list_name <- paste0(study_name, "_", country_name)
H0_matrices[[list_name]] <- as.matrix(split_df[[country_name]])
}
}
# Fit EGA dynamically
# Initialize lists for results
EGA_results <- list()
Totalgroup_comm_EGA <- list()
for (name in names(H0_matrices)) {
# Access data matrix
data_matrix <- H0_matrices[[name]]
# Fit EGA
ega_result <- EGA(data_matrix, plot.EGA = FALSE)
# Store result
EGA_results[[name]] <- ega_result
# Extract the empirical communities found by EGA
wc_result <- ega_result$wc
# Dynamically build a list of node indices for each discovered dimension
emp_groups <- list()
for (dim in unique(wc_result)) {
# Find the numeric indices of nodes belonging to this specific dimension
emp_groups[[paste("Dimension", dim)]] <- which(wc_result == dim)
}
# Store the true empirical groups to feed to qgraph
Totalgroup_comm_EGA[[name]] <- emp_groups
}
# Print the names of all the networks
names(EGA_results)
# Estimate MGM and Plot
# Expanded color palette (backups just in case EGA finds 3+ dimensions)
Totalgroup_cols_H0 <- c("#966FD6", "#006B3C", "#FFB347", "#FF6961", "#AEC6CF", "#B39EB5")
for (name in names(H0_matrices)) {
# Access data
data_matrix <- H0_matrices[[name]]
n_vars <- ncol(data_matrix)
node_names <- colnames(data_matrix)
# Dynamically generate type and level parameters for mgm
type_vec <- rep("g", n_vars)
level_vec <- rep(1, n_vars)
# Network estimation
mgm_result <- mgm(
data_matrix, type = type_vec, level = level_vec,
lambdaSel = "CV", ruleReg = "OR", verbose = FALSE, pbar = FALSE
)
# Predictability (R2 pie charts)
pred_result <- predict(object = mgm_result, data = data_matrix, errorCon = 'R2')
# Retrieve the groups
groups_EGA <- Totalgroup_comm_EGA[[name]]
# colors
current_colors <- Totalgroup_cols_H0[1:length(groups_EGA)]
# output path
output_path <- here("Output", "H0", "Country_networks", paste0(name, ".png"))
# png
png(output_path, width = 4.15, height = 5.85, units = "in", res = 600)
# Generate the qgraph plot
qgraph(
mgm_result$pairwise$wadj,
layout = "spring",
labels = node_names,
groups = groups_EGA,
color = current_colors,
legend = FALSE,
title = name,
edge.color = mgm_result$pairwise$edgecolor_cb,
vTrans = 180, borders = TRUE, vsize = 10, esize = 7, label.cex = 0.50,
label.scale = FALSE,
pie = pred_result$errors[,2],
pieColor = rep('#FFFF00', n_vars)
)
dev.off()
}
#Generate final figures for the Supplement
# Directories
input_dir <- here("Output", "H0", "Country_networks")
output_dir <- here("Output", "H0", "Composite_Figures")
dir.create(output_dir, recursive = TRUE, showWarnings = FALSE)
# Fetch all PNGs
all_pngs <- list.files(input_dir, pattern = "\\.png$", full.names = TRUE)
# STUDY 1: 8 Countries
study1_files <- all_pngs[grepl("Study1", all_pngs)]
if (length(study1_files) == 8) {
cat("Found 8 files for Study 1. Splitting into A and B...\n")
imgs_1a <- lapply(study1_files[1:4], image_read)
imgs_1b <- lapply(study1_files[5:8], image_read)
comp_1a <- image_montage(image_join(imgs_1a), tile = "2x2", geometry = "+50+50")
comp_1b <- image_montage(image_join(imgs_1b), tile = "2x2", geometry = "+50+50")
image_write(comp_1a, path = here(output_dir, "H0_Study1_Composite_A.png"), format = "png")
image_write(comp_1b, path = here(output_dir, "H0_Study1_Composite_B.png"), format = "png")
}
# STUDY 2: 1 country unchanged
study2_files <- all_pngs[grepl("Study2", all_pngs)]
if (length(study2_files) == 1) {
cat("Found 1 file for Study 2. Copying...\n")
file.copy(from = study2_files[1], to = here(output_dir, "H0_Study2_Composite.png"), overwrite = TRUE)
}
# STUDY 3 (CMQ): 8 Countries
study3_cmq_files <- all_pngs[grepl("Study3_CMQ", all_pngs)]
if (length(study3_cmq_files) == 8) {
cat("Found 8 files for Study 3 CMQ. Splitting into A and B...\n")
imgs_3a_cmq <- lapply(study3_cmq_files[1:4], image_read)
imgs_3b_cmq <- lapply(study3_cmq_files[5:8], image_read)
comp_3a_cmq <- image_montage(image_join(imgs_3a_cmq), tile = "2x2", geometry = "+50+50")
comp_3b_cmq <- image_montage(image_join(imgs_3b_cmq), tile = "2x2", geometry = "+50+50")
image_write(comp_3a_cmq, path = here(output_dir, "H0_Study3_CMQ_Composite_A.png"), format = "png")
image_write(comp_3b_cmq, path = here(output_dir, "H0_Study3_CMQ_Composite_B.png"), format = "png")
}
# Initialize lists
CFA <- list()
CFA_stats_list <- list()
for (name in names(H0_matrices)) {
data_matrix <- as.data.frame(H0_matrices[[name]])
var_names <- colnames(data_matrix)
# isolate CB and CM items
factor_1_vars <- var_names[grepl("^cb_", var_names)]
factor_2_vars <- var_names[grepl("^cm_", var_names)]
# Build the 2-factor CFA model dynamically
model <- paste0(
"Factor1_CB =~ ", paste(factor_1_vars, collapse = " + "), "\n",
"Factor2_CM =~ ", paste(factor_2_vars, collapse = " + ")
)
# Fit CFA
cfa_result <- tryCatch(
cfa(model, data = data_matrix, std.lv = TRUE),
error = function(e) {
warning(paste("CFA failed for", name, ":", e$message))
return(NULL)
}
)
# Store model and extract stats
if (!is.null(cfa_result)) {
CFA[[name]] <- cfa_result
fit_measures <- fitMeasures(cfa_result)
CFA_stats_list[[name]] <- data.frame(
Dataset = name,
Chi_Square = fit_measures["chisq"],
P_Value = fit_measures["pvalue"],
CFI = fit_measures["cfi"],
TLI = fit_measures["tli"],
RMSEA = fit_measures["rmsea"],
SRMR = fit_measures["srmr"],
BIC = fit_measures["bic"],
stringsAsFactors = FALSE
)
}
}
# Combine stats
CFA_stats_df <- do.call(rbind, CFA_stats_list)
rownames(CFA_stats_df) <- NULL
# Save
output_doc_path <- here("Output", "H0", "CFA_Fit_Stats_Master.doc")
sjPlot::tab_df(CFA_stats_df, file = output_doc_path)
# Initialize a list
alpha_stats_list <- list()
# Loop over the H0_matrices
for (name in names(H0_matrices)) {
# Access the numeric dataframe
data_matrix <- as.data.frame(H0_matrices[[name]])
var_names <- colnames(data_matrix)
# Isolate CM and CB items
cm_vars <- data_matrix[, grepl("^cm_", var_names), drop = FALSE]
cb_vars <- data_matrix[, grepl("^cb_", var_names), drop = FALSE]
# Calculate Alphas for CM
cm_alpha <- tryCatch(
psych::alpha(cm_vars)$total$raw_alpha,
warning = function(w) psych::alpha(cm_vars, check.keys = TRUE)$total$raw_alpha,
error = function(e) NA
)
# Calculate Alpha for CB
cb_alpha <- tryCatch(
psych::alpha(cb_vars)$total$raw_alpha,
warning = function(w) psych::alpha(cb_vars, check.keys = TRUE)$total$raw_alpha,
error = function(e) NA
)
# Store the results
alpha_stats_list[[name]] <- data.frame(
Dataset = name,
CM_Items = ncol(cm_vars),
Alpha_CM = round(cm_alpha, 3),
CB_Items = ncol(cb_vars),
Alpha_CB = round(cb_alpha, 3),
stringsAsFactors = FALSE
)
}
# Combine
Alpha_stats_df <- do.call(rbind, alpha_stats_list)
rownames(Alpha_stats_df) <- NULL
# Save the table locally as a .doc file
output_alpha_path <- here("Output", "H0", "Alpha_Reliability_Master.doc")
sjPlot::tab_df(Alpha_stats_df, file = output_alpha_path)
